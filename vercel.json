{
  "version": 2,
  "outputDirectory": "dist",
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php" 
    }
  },
  "routes": [
    {
      "src": "/(css|js|images|favicon.ico|robots.txt)(.*)",
      "dest": "/public/$1$2"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}