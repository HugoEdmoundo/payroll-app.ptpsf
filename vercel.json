{
  "version": 2,
  "framework": null,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "routes": [
    {
      "src": "^/build/(.*)",
      "dest": "/public/build/$1"
    },
    {
      "src": "^/images/(.*)",
      "dest": "/public/images/$1"
    },
    {
      "src": "^/css/(.*)",
      "dest": "/public/css/$1"
    },
    {
      "src": "^/js/(.*)",
      "dest": "/public/js/$1"
    },
    {
      "src": "^/favicon\\.ico$",
      "dest": "/public/favicon.ico"
    },
    {
      "src": "^/robots\\.txt$",
      "dest": "/public/robots.txt"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ],
  "env": {
    "APP_NAME": "Payroll PSF",
    "APP_ENV": "production",
    "APP_DEBUG": "true",
    "APP_TIMEZONE": "Asia/Jakarta",
    "APP_KEY": "base64:mfeNkzoy6nHX9GmWxTgUgwrK0Nd8dLdRbmt+1JXoiIw=",
    "APP_URL": "https://payroll-app-ptpsf.hugoedm.fun",
    "APP_LOCALE": "en",
    "LOG_CHANNEL": "stderr",
    "LOG_LEVEL": "error",
    "DB_CONNECTION": "pgsql",
    "DB_HOST": "db.xkmhtprgoywyvvqdbhvm.supabase.co",
    "DB_PORT": "5432",
    "DB_DATABASE": "postgres",
    "DB_USERNAME": "postgres",
    "DB_PASSWORD": "_b975C77_ChKu@m",
    "SESSION_DRIVER": "database",
    "SESSION_LIFETIME": "120",
    "CACHE_STORE": "database",
    "QUEUE_CONNECTION": "sync",
    "FILESYSTEM_DISK": "local",
    "BCRYPT_ROUNDS": "12",
    "VERCEL": "1"
  }
}
